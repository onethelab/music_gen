  "segments": [
    {
      "text": "金曜の終電空いた席に沈む億万の再生ボタン",
      "start": 19.312,
      "end": 26.422
    },
    {
      "text": "爪で押す窓ガラスに映る東京タワーの先あの日と同じ色でまだ紡いでる",
      "start": 27.143,
      "end": 36.352
    },
    {
      "text": "カセットの隙間に残った吐息巻き戻せないテープのように",
      "start": 37.233,
      "end": 46.002
    },
    {
      "text": "終電のカセット 誰にも聞こえないあなたの声だけが",
      "start": 48.123,
      "end": 54.287
    },
    {
      "text": "レールの上を走るその光が涙に",
      "start": 55.368,
      "end": 57.996
    },
    {
      "text": "ご視聴ありがとうございました",
      "start": 60.583,
      "end": 63.949
    },
    {
      "text": "自販機の明かりで缶コーヒーを選ぶ指先が覚えてるブラック砂糖なし",
      "start": 75.542,
      "end": 84.078
    },
    {
      "text": "あの笑い声だけが座っている",
      "start": 85.06,
      "end": 87.544
    },
    {
      "text": "テープが絡まる夏の終わりの 届くした約束もっと",
      "start": 93.334,
      "end": 99.831
    },
    {
      "text": "手段のカセット 誰にも聞こえないあなたの声だけがレールの上を走る",
      "start": 104.219,
      "end": 112.88
    },
    {
      "text": "主催の光が涙に変わる前にイヤホンを外して改札を抜ける",
      "start": 113.221,
      "end": 122.53
    },
    {
      "text": "by H.",
      "start": 123.151,
      "end": 123.539
    },
    {
      "text": "ご視聴ありがとうございました",
      "start": 132.871,
      "end": 135.2
    },
    {
      "text": "締めのカセット いつか擦り切れても",
      "start": 140.072,
      "end": 144.145
    },
    {
      "text": "ご視聴ありがとうございました。",
      "start": 145.449,
      "end": 146.091
    },
    {
      "text": "ご視聴ありがとうございました",
      "start": 153.47,
      "end": 157.038
    }
